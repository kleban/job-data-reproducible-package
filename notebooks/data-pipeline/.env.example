STAGE4_5_REGION_DB_PATH = "../../data/data-pipeline/stage_04_5/region_db.pkl"
STAGE4_5_COMBINED_OUTPUT_PATH = "../../data/data-pipeline/stage_04_5/combined_output.jsonl"

# -----------------------------------------------------------------------------
# Stage 5: daily joins and monthly aggregation
# -----------------------------------------------------------------------------
# Processing-status databases for unique and full observations.
STAGE5_PROCESS_UNIQUE_PATH = "../../data/data-pipeline/stage_05/process_unique.pkl"
STAGE5_PROCESS_FULL_PATH = "../../data/data-pipeline/stage_05/process_full.pkl"

