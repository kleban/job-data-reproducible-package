# =============================================================================
# Python data-pipeline configuration
# =============================================================================
# All paths are relative to notebooks/data-pipeline/.
# Copy this file to .env before running the notebooks.
# The data layout is intentionally flat within each stage: configured paths do
# not use raw/, intermediate/, or processed/ subfolders.

# -----------------------------------------------------------------------------
# Input data
# -----------------------------------------------------------------------------
# Daily job-vacancy JSON files.
INPUT_PATH = "../../data/data-pipeline/input"

# -----------------------------------------------------------------------------
# Stage 1: load, clean, deduplicate, and detect language
# -----------------------------------------------------------------------------
# Processing-status database.
STAGE1_PROCESS_PATH = "../../data/data-pipeline/stage_01/process.pkl"
# Cleaned daily output files.
STAGE1_OUTPUT_PATH = "../../data/data-pipeline/stage_01/output"
# Daily identifier, region, and click-count files.
STAGE1_ID_REGION_NCLICK_PATH = "../../data/data-pipeline/stage_01/id_region_click"
# Persistent database of unique vacancy identifiers.
STAGE1_UNIQ_ID_DB = "../../data/data-pipeline/stage_01/unic_id_db.pkl"

# Stage 1.2: one-time ESCO skills translation.
STAGE1_2_SOURCE_SKILLS_PATH = "../../data/data-pipeline/stage_01_2/skills_en.csv"
STAGE1_2_BATCH_INPUT_PATH = "../../data/data-pipeline/stage_01_2/batch_translate_en_ru.jsonl"
STAGE1_2_BATCH_OUTPUT_PATH = "../../data/data-pipeline/stage_01_2/batch_output.jsonl"
STAGE1_2_TRANSLATE_SCHEME = "../../data/data-pipeline/stage_01_2/translate_schema.json"
STAGE1_2_TRANSLATED_SKILLS_PATH = "../../data/data-pipeline/stage_01_2/skills_ru.csv"

# -----------------------------------------------------------------------------
# Stage 2: skills extraction and work-mode classification
# -----------------------------------------------------------------------------
# Processing-status database.
STAGE2_PROCESS_PATH = "../../data/data-pipeline/stage_02/process.pkl"
# Enriched daily output files.
STAGE2_OUTPUT_PATH = "../../data/data-pipeline/stage_02/output"
# Multilingual ESCO skill reference files.
SKILLS_PATH = "../../data/data-pipeline/stage_02/skills"

# -----------------------------------------------------------------------------
# Stage 3: OpenAI Batch API occupation classification
# -----------------------------------------------------------------------------
# Batch-processing status database.
STAGE3_PROCESS_PATH = "../../data/data-pipeline/stage_03/process.pkl"
# JSONL files uploaded to the Batch API.
STAGE3_INPUT_PATH = "../../data/data-pipeline/stage_03/input"
# Raw files downloaded from completed Batch API jobs.
STAGE3_OUTPUT_PATH = "../../data/data-pipeline/stage_03/output"
# Extracted and merged occupation-classification results.
STAGE3_RESULT_PATH = "../../data/data-pipeline/stage_03/result"
# Structured-output schema and classification prompt.
STAGE3_CLASSIFY_SCHEME = "../../data/data-pipeline/stage_03/classify_schema.json"
STAGE3_CLASSIFY_PROMPT = "../../data/data-pipeline/stage_03/classification_prompt.txt"

# -----------------------------------------------------------------------------
# Stage 4: ESCO occupation verification and skills mapping
# -----------------------------------------------------------------------------
# ESCO occupation, skill, and occupation-skill relation tables.
STAGE4_ESCO_DATA_PATH = "../../data/data-pipeline/stage_04/esco_data"
# Daily ESCO-enriched output files.
STAGE4_OUTPUT_PATH = "../../data/data-pipeline/stage_04/output"

# -----------------------------------------------------------------------------
# Stage 4.5: region standardization
# -----------------------------------------------------------------------------
# Structured-output schema and region-enrichment prompt.
STAGE4_5_SELECT_REGION_SCHEME = "../../data/data-pipeline/stage_04_5/select_region_schema.json"
STAGE4_5_SELECT_REGION_PROMPT = "../../data/data-pipeline/stage_04_5/select_region_prompt.txt"
# Batch API upload and download folders.
