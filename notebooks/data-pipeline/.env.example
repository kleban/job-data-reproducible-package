STAGE4_5_OUTPUT_BATCH_PATH = "../../data/data-pipeline/stage_04_5/output"
# Previous, newly generated, and final merged region databases.
STAGE4_5_REGION_PREV_DB_PATH = "../../data/data-pipeline/stage_04_5/region_db_PREV.pkl"
